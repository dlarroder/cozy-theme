{
	"name": "cozy-theme",
	"displayName": "Cozy Theme",
	"description": "A warm, cozy dark theme for VS Code that's easy on the eyes during long coding sessions.",
	"version": "0.2.0",
	"publisher": "dlarroder",
	"license": "MIT",
	"engines": {
		"vscode": "^1.80.0"
	},
	"categories": [
		"Themes"
	],
	"keywords": [
		"theme",
		"dark",
		"cozy",
		"warm",
		"color-theme"
	],
	"contributes": {
		"themes": [
			{
				"label": "Cozy Theme",
				"uiTheme": "vs-dark",
				"path": "./themes/cozy-color-theme.json"
			}
		]
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/dlarroder/cozy-theme"
	},
	"icon": "icon.png",
	"galleryBanner": {
		"color": "#0d0c0b",
		"theme": "dark"
	},
	"scripts": {
		"package": "vsce package",
		"publish": "vsce publish",
		"publish:ovsx": "ovsx publish cozy-theme-0.2.0.vsix"
	},
	"devDependencies": {
		"@vscode/vsce": "^3.2.2",
		"ovsx": "^0.10.9"
	}
}
